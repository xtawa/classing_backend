APP_ENV=production
HTTP_ADDR=:8080
PUBLIC_BASE_URL=https://api-classing.underflo.ink

# PostgreSQL is recommended for production.
DATABASE_DRIVER=pgx
DATABASE_URL=postgres://classing:replace-database-password@postgres:5432/classing?sslmode=disable

# Use at least 32 random bytes. Prefix with base64: when supplying Base64.
JWT_SECRET=replace-with-at-least-32-random-bytes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
RESET_TOKEN_TTL=30m
EMAIL_VERIFICATION_TTL=10m
EXPOSE_VERIFICATION_CODE=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
TURNSTILE_REQUIRED=false
TRUSTED_PROXIES=127.0.0.0/8,::1/128

# Used once when the email does not already exist.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password

CORS_ALLOWED_ORIGINS=https://api-classing.underflo.ink
MAX_CLOUD_DOCUMENT_BYTES=2097152
EXPOSE_RESET_TOKEN=false
SCHEDULER_ENABLED=true
RELEASE_STORAGE_DIR=/data/releases
MAX_RELEASE_ARTIFACT_BYTES=262144000
LEGAL_PRIVACY_URL=https://example.com/privacy
LEGAL_TERMS_URL=https://example.com/terms
LEGAL_CROSS_BORDER_URL=https://example.com/cross-border-transfer

# Refer to this variable from a mailbox as env:CLASSING_SMTP_PASSWORD.
CLASSING_SMTP_PASSWORD=replace-smtp-password
# Lark public mailbox IMAP/SMTP password. Use env:LARK_SMTP_PASSWORD with the Lark preset.
LARK_SMTP_PASSWORD=
